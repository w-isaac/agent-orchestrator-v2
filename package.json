{
  "name": "agent-orchestrator-v2",
  "version": "1.0.0",
  "description": "Agent Orchestrator v2",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "ts-node src/lib/migrations.ts",
    "migrate-v1": "ts-node src/scripts/migrate-v1.ts --",
    "db:seed": "ts-node src/db/seed.ts",
    "test": "vitest run",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pg": "^8.13.3",
    "pgvector": "^0.2.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/node": "^22.12.0",
    "@types/pg": "^8.11.11",
    "@types/yargs": "^17.0.33",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4",
    "vitest": "^3.0.0"
  }
}
